# Copy to .env before deploying: cp .env.production.example .env

# REQUIRED — change this to a long random string
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# App port exposed on the server (default 80)
APP_PORT=80

# Run database seed on first deploy (set false after first run)
RUN_SEED=true

# Parking settings
HOURLY_RATE=5.0
FACILITY_NAME=Smart Parking Facility
ARDUINO_INTERVAL_MS=15000
SENSOR_THRESHOLD_CM=30

# CORS (use * when frontend proxies via nginx on same domain)
CORS_ORIGIN=*
